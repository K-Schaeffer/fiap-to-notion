{
  "name": "fiap-to-notion",
  "version": "1.0.0",
  "description": "CLI pipeline that scrapes FIAP course materials, converts HLS video streams to MP4, and uploads them to Notion as embedded video blocks.",
  "author": "Kauan Schaeffer",
  "license": "MIT",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "build:start": "npm run build && npm run start",
    "start": "node dist/index.js",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "@notionhq/client": "^5.15.0",
    "dotenv": "^17.3.1",
    "ora": "^5.4.1",
    "puppeteer": "^24.40.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ora": "^3.1.0",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  }
}
