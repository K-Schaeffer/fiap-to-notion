FIAP_USERNAME=your_username
FIAP_PASSWORD=your_password

NOTION_TOKEN=your_notion_token
NOTION_PHASES_DB_ID=your_notion_phases_db_id

# Optional — limit parallel ffmpeg processes in Video Converter (default: unlimited)
# FFMPEG_CONCURRENCY=5

# Optional — limit parallel class uploads in Notion Uploader (default: 3, matches Notion's ~3 req/s rate limit)
# Set to 0 for unlimited (may cause 429/timeout errors on large phases)
# NOTION_UPLOAD_CONCURRENCY=3
